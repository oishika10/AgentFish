# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional override (default: gemini-2.0-flash)
GEMINI_MODEL=

# Set to true to log Gemini + API output (off by default)
LOG_SUPPLY_SEARCH=

# Stadia Maps (map tiles). Required on Vercel; localhost often works without it.
# https://client.stadiamaps.com/ — create a property and copy the API key.
NEXT_PUBLIC_STADIA_MAPS_API_KEY=

